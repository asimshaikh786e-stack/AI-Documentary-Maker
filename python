class ScriptGenerator:
    def __init__(self):
        # Using new OpenAI client initialization
        self.client = OpenAI(api_key=settings.openai_api_key)
    
    def generate_script(self, prompt: str, target_duration_minutes: int = 60) -> Dict[str, Any]:
        logger.info(f"Generating script for prompt: {prompt[:50]}...")
        
        system_prompt = "You are an expert documentary screenwriter."
        user_message = f"Create a {target_duration_minutes}-minute documentary script about: {prompt}. Needs 3-act structure and visual cues."
        
        # Fixed: New API call syntax
        response = self.client.chat.completions.create(
            model="gpt-4",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_message}
            ],
            temperature=0.7,
            max_tokens=8000,
        )
        
        full_script = response.choices[0].message.content
        word_count = len(full_script.split())
        
        return {
            "full_script": full_script,
            "word_count": word_count,
            "visual_style_guide": "Cinematic, warm lighting, shallow depth of field, 4k documentary style."
        }

class StoryboardGenerator:
    def __init__(self):
        self.client = OpenAI(api_key=settings.openai_api_key)
    
    def generate_storyboard(self, script: str, visual_style_guide: str, target_scene_count: int = 5) -> List[Dict[str, Any]]:
        # Set target_scene_count low for testing, make it 100 for production
        logger.info("Generating storyboard...")
        
        response = self.client.chat.completions.create(
            model="gpt-4",
            messages=[
                {"role": "system", "content": "You are a professional storyboard artist. Output ONLY valid JSON array."},
                {"role": "user", "content": f"Break this script into {target_scene_count} scenes. Return JSON array with keys: scene_number, duration_seconds, voiceover_text, visual_prompt, cinematography_direction.\n\nScript: {script[:2000]}"}
            ],
            temperature=0.7,
            max_tokens=4000,
        )
        
        try:
            scenes = json.loads(response.choices[0].message.content)
            return scenes
        except json.JSONDecodeError:
            logger.error("Failed to parse JSON storyboard. Returning basic scene.")
            return [{"scene_number": 1, "duration_seconds": 10, "voiceover_text": "Starting the documentary.", "visual_prompt": "Cinematic establishing shot.", "cinematography_direction": "Wide shot."}]

